{
  "name": "alt-calculator-app",
  "version": "1.0.0",
  "description": "Alt Booking Calculator Desktop Application",
  "author": {
    "name": "Alt Calculator Team",
    "email": "support@altcalculator.com"
  },
  "homepage": "https://altcalculator.com",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "pack": "./build.sh"
  },
  "build": {
    "appId": "com.alt.calculator",
    "productName": "Alt Calculator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "frontend/build",
        "to": "frontend/build",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office",
      "icon": "build/icon.png",
      "maintainer": "Alt Calculator Team <support@altcalculator.com>",
      "vendor": "Alt Calculator",
      "synopsis": "Booking price calculator for Alt properties",
      "description": "Calculate booking prices for Alt properties with various options and discounts"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.business"
    }
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-serve": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^27.1.0",
    "electron-builder": "^24.6.4",
    "wait-on": "^7.2.0"
  },
  "license": "MIT"
} 